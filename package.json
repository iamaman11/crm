{
  "name": "ultimate-crm-product-plane",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=24.18.0 <25",
    "pnpm": ">=11.12.0 <12"
  },
  "scripts": {
    "web:generate": "buf generate --template buf.gen.web.yaml",
    "web:typecheck": "pnpm web:generate && pnpm --filter './packages/**' --filter './apps/**' typecheck",
    "web:lint": "pnpm --filter './packages/**' --filter './apps/**' lint",
    "web:test": "pnpm --filter './packages/**' --filter './apps/**' test",
    "web:build": "pnpm web:generate && pnpm --filter @ultimate-crm/web build",
    "web:check": "pnpm web:typecheck && pnpm web:lint && pnpm web:test && pnpm web:build"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.66.1",
    "@bufbuild/protoc-gen-es": "2.12.1",
    "oxlint": "1.72.0",
    "typescript": "6.0.2"
  }
}
