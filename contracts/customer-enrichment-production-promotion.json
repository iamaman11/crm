    "registration_owner": "module_owned_contribution",
    "central_business_route_switches_allowed": false,
    "production_readiness_requires_single_exact_head": true,
    "required_exact_head_workflows": 17,
    "retain_provenance_on_uninstall": true
  },
  "promotion_stages": [
    {
      "stage": 1,
      "name": "accepted_suggestion_application",
      "coordinates": [
        {
          "id": "customer_enrichment.application.outcome.record",
          "version": "1.0.0",
          "route_kind": "worker_mutation",
          "exposure": "worker_only",
          "implementation_crate": "crm-customer-enrichment-application-composition",
          "depends_on": [
            "customer_enrichment.party.display_name.apply@1.0.0"
          ],
          "required_evidence": [
            "activation_gated_worker_registration",
            "append_once_outcome",
            "policy_decision_causation_lineage",
            "conflicting_outcome_fail_closed",
            "completed_attempt_replay_suppression",
            "disable_uninstall",
            "cross_tenant",
            "exact_head_17_workflows"
          ]
        }
      ]
    },
    {
      "stage": 2,
      "name": "provider_worker_pipeline",
      "coordinates": [
        {
          "id": "customer_enrichment.request.dispatch",
          "version": "1.0.0",
          "route_kind": "worker_mutation",
          "exposure": "worker_only",
          "implementation_crate": "crm-customer-enrichment-worker-composition",
          "depends_on": [
            "customer_enrichment.request.create@1.0.0"
          ],
          "required_evidence": [
            "activation_gated_worker_registration",
            "exact_provider_registry",
            "provider_disabled",
            "quota_and_circuit_failure",
            "sanitized_provider_errors",
            "restart_recovery",
            "disable_uninstall",
            "cross_tenant",
            "exact_head_17_workflows"
          ]
        },
        {
          "id": "customer_enrichment.response.record",
          "version": "1.0.0",
          "route_kind": "worker_mutation",
          "exposure": "worker_only",
          "implementation_crate": "crm-customer-enrichment-worker-composition",
          "depends_on": [
            "customer_enrichment.request.dispatch@1.0.0"
          ],
          "required_evidence": [
            "activation_gated_worker_registration",
            "conflicting_response_fail_closed",
            "immutable_receipt_and_usage_evidence",
            "response_reconciliation",
            "sanitized_provider_errors",
            "disable_uninstall",
            "cross_tenant",
            "exact_head_17_workflows"
          ]
        },
        {
          "id": "customer_enrichment.suggestions.materialize",
          "version": "1.0.0",
          "route_kind": "worker_mutation",
          "exposure": "worker_only",
          "implementation_crate": "crm-customer-enrichment-materialization-composition",
          "depends_on": [
            "customer_enrichment.response.record@1.0.0"
          ],
          "required_evidence": [
            "activation_gated_worker_registration",
            "immutable_dependency_validation",
            "deterministic_materialization",
            "response_materialization_recovery",
            "expiry_reconciliation",
            "disable_uninstall",
            "cross_tenant",
            "exact_head_17_workflows"
          ]
        }
      ]
    }
  ]
}
