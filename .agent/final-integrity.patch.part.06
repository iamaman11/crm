-+## Production contribution boundary
-+
-+`scaffold_module.py` creates two separately owned workspace members: the infrastructure-neutral business module under `modules/` and a production composition crate under `crates/<module>-composition/`. The generated composition entrypoint is deliberately fail-closed with `MODULE_PRODUCTION_CONTRIBUTION_NOT_IMPLEMENTED`; it must be replaced by reviewed exact mutation/query registrations, semantic validators and activation-gated workers before production wiring.
-+
-+Compiled first-party production coordinates must equal `contracts/module-contract-bindings.json`. Platform-owned runtime coordinates and intentionally non-runtime governed coordinates are listed individually, with reasons, in `contracts/production-route-classifications.json`; owner-wide and pattern allowlists are forbidden.
-diff --git a/scripts/check_production_route_classifications.py b/scripts/check_production_route_classifications.py
-new file mode 100644
-index 0000000..40b6074
---- /dev/null
-+++ b/scripts/check_production_route_classifications.py
-@@ -0,0 +1,62 @@
-+#!/usr/bin/env python3
-+"""Validate exact production route classifications against governed bindings."""
-+
-+from __future__ import annotations
-+
-+import json
-+from pathlib import Path
-+
-+ROOT = Path(__file__).resolve().parents[1]
-+BINDINGS = ROOT / "contracts/module-contract-bindings.json"
-+CLASSIFICATIONS = ROOT / "contracts/production-route-classifications.json"
-+
-+Coordinate = tuple[str, str, str]
-+
-+def coordinate(route: dict[str, object]) -> Coordinate:
-+    values = tuple(str(route.get(key, "")).strip() for key in ("owner_module_id", "id", "version"))
-+    if not all(values):
-+        raise ValueError(f"route classification has an empty coordinate: {route!r}")
-+    return values  # type: ignore[return-value]
-+
-+def load_and_validate() -> tuple[set[Coordinate], set[Coordinate]]:
-+    bindings = json.loads(BINDINGS.read_text(encoding="utf-8"))
-+    classifications = json.loads(CLASSIFICATIONS.read_text(encoding="utf-8"))
-+    if bindings.get("schema_version") != "crm.contract-bindings/v1":
-+        raise ValueError("unexpected contract binding schema version")
-+    if classifications.get("schema_version") != "crm.production-route-classifications/v1":
-+        raise ValueError("unexpected production route classification schema version")
-+    governed = {
-+        (module["module_id"], capability["id"], capability["version"])
-+        for module in bindings["modules"]
-+        for capability in module["capabilities"]
-+    }
-+    groups: dict[str, set[Coordinate]] = {}
-+    for key in ("platform_runtime_routes", "non_runtime_contract_routes"):
-+        routes = classifications.get(key)
-+        if not isinstance(routes, list):
-+            raise ValueError(f"{key} must be a list")
-+        coordinates: list[Coordinate] = []
-+        for route in routes:
-+            if not isinstance(route, dict) or not str(route.get("reason", "")).strip():
-+                raise ValueError(f"{key} entry requires a non-empty reason")
-+            coordinates.append(coordinate(route))
-+        if len(coordinates) != len(set(coordinates)):
-+            raise ValueError(f"duplicate exact coordinate in {key}")
-+        groups[key] = set(coordinates)
-+    platform = groups["platform_runtime_routes"]
-+    non_runtime = groups["non_runtime_contract_routes"]
-+    if platform & non_runtime:
-+        raise ValueError("platform and non-runtime classifications overlap")
-+    if platform & governed:
-+        raise ValueError("platform runtime classifications must be outside governed business bindings")
-+    if not non_runtime <= governed:
-+        raise ValueError("non-runtime classifications must name governed binding coordinates")
-+    return platform, non_runtime
-+
-+def main() -> int:
-+    platform, non_runtime = load_and_validate()
-+    print(f"Production route classifications valid: {len(platform)} platform routes, {len(non_runtime)} non-runtime routes.")
-+    return 0
-+
-+if __name__ == "__main__":
-+    raise SystemExit(main())
