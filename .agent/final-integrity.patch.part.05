-+-- Test-only lifecycle provisioning. Production activation is never bootstrapped
-+-- in process memory: every published fixture module receives a durable active
-+-- installation row, and later adapter fixtures are activated by this trigger.
-+CREATE OR REPLACE FUNCTION crm.test_activate_module_version(
-+  requested_module_id text,
-+  requested_version text
-+) RETURNS void
-+LANGUAGE plpgsql
-+AS $$
-+DECLARE
-+  tenant_row record;
-+  bootstrap_transaction_id text;
-+BEGIN
-+  FOR tenant_row IN SELECT tenant_id FROM crm.tenants ORDER BY tenant_id LOOP
-+    bootstrap_transaction_id := CASE tenant_row.tenant_id
-+      WHEN 'tenant-a' THEN 'tx-bootstrap-a'
-+      WHEN 'tenant-b' THEN 'tx-bootstrap-b'
-+      ELSE NULL
-+    END;
-+    IF bootstrap_transaction_id IS NULL THEN
-+      CONTINUE;
-+    END IF;
-+    INSERT INTO crm.module_installations (
-+      tenant_id, install_id, module_id, current_version, status, generation,
-+      grant_set_digest, last_business_transaction_id
-+    ) VALUES (
-+      tenant_row.tenant_id,
-+      'fixture:' || requested_module_id,
-+      requested_module_id,
-+      requested_version,
-+      'active',
-+      1,
-+      decode(repeat(substr(md5(tenant_row.tenant_id || ':' || requested_module_id || ':' || requested_version), 1, 2), 32), 'hex'),
-+      bootstrap_transaction_id
-+    )
-+    ON CONFLICT (tenant_id, module_id) DO UPDATE SET
-+      current_version = EXCLUDED.current_version,
-+      status = 'active',
-+      pending_version = NULL,
-+      failure_code = NULL,
-+      generation = CASE
-+        WHEN crm.module_installations.current_version <> EXCLUDED.current_version
-+          OR crm.module_installations.status <> 'active'
-+        THEN crm.module_installations.generation + 1
-+        ELSE crm.module_installations.generation
-+      END,
-+      grant_set_digest = EXCLUDED.grant_set_digest,
-+      last_business_transaction_id = EXCLUDED.last_business_transaction_id,
-+      updated_at = clock_timestamp();
-+  END LOOP;
-+END;
-+$$;
-+
-+CREATE OR REPLACE FUNCTION crm.test_activate_published_module_version()
-+RETURNS trigger
-+LANGUAGE plpgsql
-+AS $$
-+BEGIN
-+  PERFORM crm.test_activate_module_version(NEW.module_id, NEW.version);
-+  RETURN NEW;
-+END;
-+$$;
-+
-+CREATE TRIGGER test_module_version_activation
-+AFTER INSERT OR UPDATE ON crm.module_versions
-+FOR EACH ROW EXECUTE FUNCTION crm.test_activate_published_module_version();
-+
-+DO $$
-+DECLARE
-+  module_row record;
-+BEGIN
-+  FOR module_row IN
-+    SELECT DISTINCT ON (module_id) module_id, version
-+    FROM crm.module_versions
-+    ORDER BY module_id, published_at DESC, version DESC
-+  LOOP
-+    PERFORM crm.test_activate_module_version(module_row.module_id, module_row.version);
-+  END LOOP;
-+END;
-+$$;
-+
- DO $$
- DECLARE
-   visible_count integer;
