+fn classified(routes: &[ClassifiedRoute], label: &str) -> BTreeSet<Coordinate> {
+    for route in routes { assert!(!route.reason.trim().is_empty(), "{label} classification lacks reason"); }
+    unique(routes.iter().map(|route| (route.owner_module_id.clone(), route.id.clone(), route.version.clone())), label)
 }
