+fn governed_contracts_equal_production_routes_exactly() {
+    let root = PathBuf::from(env!("CARGO_MANIFEST_DIR")).join("../..");
+    let bindings: ContractBindings = serde_json::from_str(&fs::read_to_string(root.join("contracts/module-contract-bindings.json")).unwrap()).unwrap();
+    let classifications: RouteClassifications = serde_json::from_str(&fs::read_to_string(root.join("contracts/production-route-classifications.json")).unwrap()).unwrap();
+    assert_eq!(bindings.schema_version, "crm.contract-bindings/v1");
+    assert_eq!(classifications.schema_version, "crm.production-route-classifications/v1");
+    let governed = unique(bindings.modules.into_iter().flat_map(|module| module.capabilities.into_iter().map(move |capability| (module.module_id.clone(), capability.id, capability.version))), "governed contract bindings");
+    let platform = classified(&classifications.platform_runtime_routes, "platform runtime");
+    let non_runtime = classified(&classifications.non_runtime_contract_routes, "non-runtime contract");
+    assert!(platform.is_disjoint(&non_runtime), "route classifications overlap");
+    assert!(non_runtime.is_subset(&governed), "non-runtime classifications must name governed contract routes");
+    let mut expected = governed.difference(&non_runtime).cloned().collect::<BTreeSet<_>>();
+    expected.extend(platform);
+    let mutations = application_mutation_definitions().unwrap();
+    let queries = application_query_definitions().unwrap();
+    assert_kinds_are_disjoint(&mutations, &queries);
+    let actual = unique(mutations.iter().chain(&queries).map(route_coordinate), "production route inventory");
+    assert_eq!(expected, actual, "manifest/binding/production route drift");
 }
 
